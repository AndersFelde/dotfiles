// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "hide_gitignore": false,
    "hide_hidden": false
  },
  "agent": {
    "profiles": {
      "test": {
        "name": "test",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "gemini-3.1-pro-preview",
      "enable_thinking": false
    },
    "favorite_models": [],
    "default_profile": "ask",
    "model_parameters": [],
  },
  "inlay_hints": {
    "enabled": true,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "diff_view_style": "split",
  "git_panel": {
    "tree_view": true,
  },
  "wsl_connections": [
    {
      "distro_name": "archlinux",
      "user": null,
      "projects": [
        {
          "paths": ["/home/kippster/code/demo/./"],
        },
      ],
    },
  ],
  "vim_mode": true,
  "terminal": {
    "minimum_contrast": 38.0,
    "shell": "system",
    "font_family": "CaskaydiaCove NF",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "preview_tabs": {
    "enabled": false,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "minimap": {
    "show": "never",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "format_on_save": "off",
  "buffer_font_fallbacks": ["CaskaydiaCove NF", "Courier New"],
  "buffer_font_family": "CaskaydiaCove Nerd Font",
  "show_edit_predictions": true,
  "icon_theme": "Zed (Default)",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark Pro",
  },
  "which_key": { "enabled": true, "delay_ms": 200 },
  "auto_install_extensions": {
    "one-dark-pro": true,
  },
  "semantic_tokens": "combined",
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
  },
  "theme_overrides": {
    "One Dark Pro": {
      "syntax": {
        "function": {
          "font_weight": 900,
        },
      },
      "accents": ["#d19a66", "#c678dd", "#56b6c2"],
    },
  },
  "colorize_brackets": true,
  "global_lsp_settings": {
    "semantic_token_rules": [
      {
        "token_type": "macro",
        "style": ["attribute"],
      },
      {
        "token_type": "enum",
        "style": ["type"],
      },
      {
        "token_type": "enumMember",
        "style": ["enum"],
      },
    ],
  },
  "search_on_input": true
}
